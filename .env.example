APP_ENV=dev
MYSQL_DSN=mysql+pymysql://tm_app:123456@127.0.0.1:3306/tm_assistant
REDIS_URL=redis://127.0.0.1:6379/0
JWT_SECRET=replace_me
OPENAI_API_KEY=replace_me
JWT_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_DAYS=14

# Web chat visitor fallback claims (for unauthenticated /api/v1/tm/chat/*)
VISITOR_TENANT_ID=1001
VISITOR_USER_ID=0
VISITOR_ROLE=visitor

# Connector webhook mock
CONNECTOR_VERIFY_SIGNATURE=false
FEISHU_SIGN_SECRET=replace_me
WECOM_SIGN_SECRET=replace_me

# Comma-separated origins for browser access to api-gateway
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Billing minimal controls
BILLING_DEFAULT_PLAN=starter
BILLING_DAILY_MESSAGE_QUOTA=500

# Worker queues
JOB_QUEUE_NAME=tm:jobs
JOB_DLQ_NAME=tm:jobs:dlq
JOB_MAX_RETRIES=3

API_GATEWAY_PORT=18000
ASSISTANT_CORE_PORT=18001
CONNECTOR_SERVICE_PORT=18002
