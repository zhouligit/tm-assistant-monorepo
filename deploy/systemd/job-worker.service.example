[Unit]
Description=TM Assistant Job Worker
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/tm-assistant-monorepo/job-worker
EnvironmentFile=/opt/tm-assistant-monorepo/.env
ExecStart=/opt/tm-assistant-monorepo/.venv/bin/python -m app.worker
Restart=always
RestartSec=3
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
